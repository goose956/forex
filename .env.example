# =============================================================
# FOREX SIGNAL TRACKER -- ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub -- it is in .gitignore.
# =============================================================

# LLM PROVIDERS (required)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# MARKET DATA (required -- free at alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your-alphavantage-key-here

# DATABASE (required -- get from Railway dashboard: Settings > Database > Connection URL)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# TRADING SETTINGS
DEFAULT_PAIR=GBPUSD=X
DEFAULT_PROVIDER=anthropic
ANALYSIS_DEPTH=deep
TIMEZONE=Europe/London

# ACCOUNT (used for position sizing calculations)
ACCOUNT_BALANCE_GBP=1000
MAX_RISK_PER_TRADE_PCT=1.0
MIN_RISK_REWARD=2.0

# COST ALERTS (optional -- script warns if daily spend exceeds this)
MAX_DAILY_SPEND_GBP=5.00
